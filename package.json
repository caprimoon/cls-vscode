{
  "name": "cls-telegraph-viewer",
  "displayName": "实时电报",
  "description": "实时获取财联社电报等(后续补充更多来源)",
  "version": "2.0.0",
  "publisher": "KayleMoon",
  "repository": {
    "type": "git",
    "url": "https://github.com/caprimoon/cls-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/caprimoon/cls-vscode/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "财联社",
    "电报",
    "新闻",
    "财经"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onView:clsTelegraphList",
    "onCommand:cls-telegraph.fetchTelegraph",
    "onCommand:cls-telegraph.viewAllTelegraphs"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cls-telegraph-container",
          "title": "实时电报",
          "icon": "resources/telegraph.svg"
        }
      ]
    },
    "views": {
      "cls-telegraph-container": [
        {
          "id": "clsTelegraphList",
          "name": "电报列表"
        }
      ]
    },
    "commands": [
      {
        "command": "cls-telegraph.fetchTelegraph",
        "title": "刷新电报",
        "icon": "$(refresh)"
      },
      {
        "command": "cls-telegraph.viewAllTelegraphs",
        "title": "查看全部电报",
        "icon": "$(list-ordered)"
      },
      {
        "command": "cls-telegraph.viewTelegraph",
        "title": "查看详情"
      },
      {
        "command": "cls-telegraph.clearNotifications",
        "title": "清除通知",
        "icon": "$(check)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cls-telegraph.fetchTelegraph",
          "when": "view == clsTelegraphList",
          "group": "navigation@1"
        },
        {
          "command": "cls-telegraph.viewAllTelegraphs",
          "when": "view == clsTelegraphList",
          "group": "navigation@2"
        },
        {
          "command": "cls-telegraph.clearNotifications",
          "when": "view == clsTelegraphList",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "cls-telegraph.viewTelegraph",
          "when": "view == clsTelegraphList"
        }
      ]
    },
    "configuration": {
      "title": "实时电报",
      "properties": {
        "clsTelegraph.autoRefreshInterval": {
          "type": "number",
          "default": 10,
          "description": "自动刷新间隔（秒）",
          "minimum": 5,
          "maximum": 300
        },
        "clsTelegraph.enableAutoRefresh": {
          "type": "boolean",
          "default": false,
          "description": "启用自动刷新"
        },
        "clsTelegraph.enableNotifications": {
          "type": "boolean",
          "default": true,
          "description": "启用新电报通知"
        },
        "clsTelegraph.maxTelegraphCount": {
          "type": "number",
          "default": 50,
          "description": "最大保存电报数量"
        },
        "clsTelegraph.sources": {
          "type": "array",
          "default": [
            {
              "name": "财联社",
              "url": "https://www.cls.cn/telegraph",
              "selector": ".telegraph-content-box",
              "enabled": true
            }
          ],
          "description": "配置消息来源列表"
        }
      }
    }
  },
  "dependencies": {
    "axios": "^0.24.0",
    "cheerio": "^1.0.0-rc.10"
  }
}
